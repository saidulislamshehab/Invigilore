# ============================================
# Invigilore — Docker Environment Variables
# ============================================
# Copy this file to .env and customize values.
# Usage: cp .env.example .env

# ── App ───────────────────────────────────
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# ── Ports ─────────────────────────────────
FRONTEND_PORT=5173
NGINX_PORT=8080
DB_PORT=1433
# PMA_PORT removed (phpMyAdmin not used for MSSQL)

# ── Database ──────────────────────────────
DB_DATABASE=invigilore
DB_USERNAME=sa
DB_PASSWORD=YourStrong!Passw0rd
# DB_ROOT_PASSWORD removed (not used for MSSQL)
